<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/layoutInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Автоматический слайдер картинок -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="250dp">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerImages"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageButton
                android:id="@+id/btnLeftArrow"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:padding="4dp"
                android:background="@android:drawable/screen_background_light_transparent"
                android:src="@android:drawable/arrow_down_float"
                android:rotation="270"
                android:contentDescription="Предыдущая картинка"
                android:elevation="8dp" />

            <ImageButton
                android:id="@+id/btnRightArrow"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:padding="4dp"
                android:background="@android:drawable/screen_background_light_transparent"
                android:src="@android:drawable/arrow_down_float"
                android:rotation="270"
                android:contentDescription="Следующая картинка"
                android:elevation="8dp" />

        </RelativeLayout>

        <!-- Индикатор страниц -->
        <TextView
            android:id="@+id/tvImageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="15dp"
            android:textSize="12sp"
            android:textColor="#999999"
            android:text="1 из 3" />

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:text="Название феста" />

        <TextView
            android:id="@+id/tvDetailDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.2"
            android:textColor="#666666"
            android:text="Описание будет тут..." />

        <Button
            android:id="@+id/btnMap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="📍 Посмотреть место на карте"
            android:backgroundTint="#9C27B0" />

        <Button
            android:id="@+id/btnRegisterFest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Зарегистрироваться на фест"
            android:backgroundTint="#4CAF50" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutTicket"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ваш электронный билет"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="20dp"/>

        <ImageView
            android:id="@+id/ivTicketQr"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:padding="20dp"
            android:background="@android:drawable/editbox_background"/>

        <TextView
            android:id="@+id/tvTicketDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Дата: 16 Июля 2026"
            android:layout_marginTop="10dp"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#757575"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Назад к списку"
        android:layout_marginTop="40dp"
        android:backgroundTint="#2196F3"/>
    <Button
        android:id="@+id/btnUnregisterFest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#E53935"
        android:text="Отменить регистрацию"
        android:textColor="@android:color/white"
        android:visibility="gone"/>
</LinearLayout>